# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────
# IMPORTANTE: usar el endpoint "-pooler" de Neon (PgBouncer). Los parámetros
# `pgbouncer`/`connection_limit` de Prisma NO tienen efecto con el patrón
# @prisma/adapter-pg + pg.Pool usado en src/lib/prisma.ts — el tamaño real del
# pool se controla ahí, no en esta URL.
DATABASE_URL="postgresql://user:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/cajarus?sslmode=require"

# ──────────────────────────────────────────
# Auth (NextAuth.js v5 + Google OAuth)
# ──────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GOOGLE_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
AUTH_URL="http://localhost:3000"
# Solo necesaria si se despliega FUERA de Vercel (Vercel la detecta sola vía
# la env var VERCEL=1). Sin esto, Auth.js v5 puede rechazar el host con
# el error "UntrustedHost".
# AUTH_TRUST_HOST="true"

# Correos (separados por coma, sin espacios) que se activan automáticamente
# como ADMIN en su primer login con Google. Cualquier otro correo que inicie
# sesión se crea como CASHIER con isActive=false, pendiente de activación
# manual por un ADMIN (por ahora, vía Prisma Studio: pnpm db:studio).
# IMPORTANTE: define esto ANTES del primer login o nadie podrá operar el
# sistema como administrador.
BOOTSTRAP_ADMIN_EMAILS="tucorreo@gmail.com"

# Nombre del tenant inicial (la bodega principal) que se crea cuando entra el
# primer ADMIN bootstrap. Si no lo defines, la app usa "Mi bodega".
BOOTSTRAP_TENANT_NAME="Mi bodega"

# ──────────────────────────────────────────
# Cloudflare R2 (Invoice Images)
# ──────────────────────────────────────────
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="cajarus-invoices"
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://pub-<hash>.r2.dev"

# ──────────────────────────────────────────
# AI / OCR
# ──────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
